// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  name       String
  createdAt  DateTime    @default(now()) @map("created_at")
  friends    Friend[]
  gatherings Gathering[]

  @@map("users")
}

model Friend {
  id           String                  @id @default(uuid())
  userId       String                  @map("user_id")
  name         String
  createdAt    DateTime                @default(now()) @map("created_at")
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants GatheringParticipant[]

  @@map("friends")
}

model Gathering {
  id           String                  @id @default(uuid())
  userId       String                  @map("user_id")
  title        String
  heldAt       DateTime                @map("held_at")
  location     String
  restaurant   String?
  drinks       String[]
  notes        String?
  createdAt    DateTime                @default(now()) @map("created_at")
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  participants GatheringParticipant[]
  diary        DiaryEntry?
  photos       Photo[]

  @@map("gatherings")
}

model GatheringParticipant {
  id          String    @id @default(uuid())
  gatheringId String    @map("gathering_id")
  friendId    String    @map("friend_id")
  gathering   Gathering @relation(fields: [gatheringId], references: [id], onDelete: Cascade)
  friend      Friend    @relation(fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([gatheringId, friendId])
  @@map("gathering_participants")
}

model DiaryEntry {
  id          String    @id @default(uuid())
  gatheringId String    @unique @map("gathering_id")
  content     String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  gathering   Gathering @relation(fields: [gatheringId], references: [id], onDelete: Cascade)

  @@map("diary_entries")
}

model Photo {
  id          String    @id @default(uuid())
  gatheringId String    @map("gathering_id")
  url         String
  caption     String?
  sortOrder   Int       @default(0) @map("sort_order")
  uploadedAt  DateTime  @default(now()) @map("uploaded_at")
  gathering   Gathering @relation(fields: [gatheringId], references: [id], onDelete: Cascade)

  @@map("photos")
}
